{
  "name": "gbrain-capture",
  "version": "0.1.0",
  "description": "Chrome extension to capture web content into ClipBrain",
  "private": true,
  "scripts": {
    "vendor": "cp node_modules/@mozilla/readability/Readability.js lib/readability.js",
    "setup": "./setup.sh",
    "backfill": "bun run backfill.ts",
    "corpus": "bun run corpus-report.ts",
    "cleanup-plan": "bun run cleanup-plan.ts",
    "cleanup-apply": "bun run cleanup-apply.ts",
    "mcp": "bun run clipbrain-mcp.ts",
    "serve": "bun run server.ts",
    "serve:bg": "bun run server.ts &",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@mozilla/readability": "^0.6.0",
    "pdf-parse": "^2.4.5"
  }
}
